{
  "expo": {
    "name": "ClosetAI",
    "slug": "closetai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "closetai",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of your clothes",
        "NSPhotoLibraryUsageDescription": "Pick clothing photos from your gallery"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FAFAFA"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["CAMERA", "READ_MEDIA_IMAGES", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAFAFA"
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "ClosetAI accesses your gallery to add clothing photos.",
          "cameraPermission": "ClosetAI uses your camera to capture clothing photos."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "ClosetAI uses your camera to capture clothing photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
